{
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/dashboard",
      "destination": "/customer-dashboard.html"
    },
    {
      "source": "/contractor",
      "destination": "/contractor-dashboard.html"
    },
    {
      "source": "/admin",
      "destination": "/admin-dashboard.html"
    },
    {
      "source": "/login",
      "destination": "/tradease-auth.html"
    },
    {
      "source": "/signup",
      "destination": "/tradease-auth.html"
    },
    {
      "source": "/callback",
      "destination": "/auth-callback.html"
    },
    {
      "source": "/success",
      "destination": "/success.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
